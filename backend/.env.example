# Anthropic (Claude Agent SDK)
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca Markets (https://alpaca.markets 에서 발급)
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
# true = 페이퍼(모의) 트레이딩, false = 실전 매매 (라이브 키 필요)
ALPACA_PAPER=true

# 한국투자증권 KIS Developers (https://apiportal.koreainvestment.com)
# 실전 키 — 시세/차트/실계좌 잔고 조회 전용 (주문에는 사용되지 않음)
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT=12345678-01
# 모의투자 키 — 국내 주식 모의 주문 전용 (모의투자 신청 후 발급, 선택)
KIS_VTS_APP_KEY=
KIS_VTS_APP_SECRET=
KIS_VTS_ACCOUNT=

# 에이전트 모델 (claude-sonnet-5 / claude-fable-5)
AGENT_MODEL=claude-sonnet-5

# 모바일 앱이 보내는 X-API-Key 값 (아무 문자열, 앱 설정과 일치시킬 것)
APP_API_KEY=dev-key

# 1회 주문 금액 상한 (USD)
MAX_ORDER_VALUE=5000
